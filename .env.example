# Aero Shield v1.8 — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.

# OpenAQ v3 — Air quality data
# Get yours at: https://explore.openaq.org/
OPENAQ_API_KEY=your_openaq_api_key_here

# OpenWeatherMap — Meteorological data
# Get yours at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here

# TomTom Pro Traffic — Urban mobility data
# Get yours at: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# AWS credentials (for pipeline deployment)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=ap-south-1

# S3 bucket names
S3_RAW_BUCKET=aero-shield-raw-zone
S3_CURATED_BUCKET=aero-shield-curated-zone

# Redshift connection (for warehouse layer)
REDSHIFT_HOST=your-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=aero_shield
REDSHIFT_USER=your_user
REDSHIFT_PASSWORD=your_password

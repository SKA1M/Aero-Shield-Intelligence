# ==============================================================================
# AERO SHIELD API CONFIGURATION TEMPLATE
# Instructions: Copy this file to a new file named '.env' and add your keys.
# ==============================================================================

# OpenAQ API Key (Get one at https://explore.openaq.org/)
OPENAQ_API_KEY=your_openaq_key_here

# OpenWeatherMap API Key (Get one at https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key_here

# TomTom Search/Traffic API Key (Get one at https://developer.tomtom.com/)
TOMTOM_API_KEY=your_tomtom_key_here